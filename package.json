{
  "name": "warchief",
  "version": "1.0.0",
  "description": "You are the only human on the battlefield. Everyone else is an agent.",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "npx tsx src/main.ts",
    "battle": "npx tsx src/main.ts basic",
    "assault": "npx tsx src/main.ts assault",
    "demo": "npx tsx src/demo.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ishnoor-Singh/warchief.git"
  },
