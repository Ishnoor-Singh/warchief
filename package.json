{
  "name": "warchief",
  "version": "1.0.0",
  "description": "You are the only human on the battlefield. Everyone else is an agent.",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:client && npm run build:server",
    "build:server": "tsc",
    "build:client": "cd client && npm run build",
    "start": "node dist/server/index.js",
    "dev": "npx tsx src/server/index.ts",
    "dev:client": "cd client && npm run dev",
    "battle": "npx tsx src/main.ts basic",
    "assault": "npx tsx src/main.ts assault",
    "demo": "npx tsx src/demo.ts",
    "headless": "npx tsx src/headless.ts",
    "headless:assault": "npx tsx src/headless.ts --scenario assault",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ishnoor-Singh/warchief.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Ishnoor-Singh/warchief/issues"
  },
  "homepage": "https://github.com/Ishnoor-Singh/warchief#readme",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  }
}
