  },
  "homepage": "https://github.com/Ishnoor-Singh/warchief#readme",
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@types/node": "^25.3.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
